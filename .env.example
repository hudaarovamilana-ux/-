BOT_TOKEN=your_bot_token_from_BotFather
# Необязательно — путь к SQLite (Railway Volume и т.п.)
# DATABASE_PATH=/data/pregnancy_bot.db

# DeepSeek — для ИИ-ответов на вопросы беременных
DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_MODEL=deepseek-v4-flash

# Telegram user_id гинеколога (через запятую). Узнать id: команда /myid в боте или @userinfobot
# Важно: гинеколог должна нажать Start у бота до получения уведомлений
EXPERT_CHAT_IDS=123456789
